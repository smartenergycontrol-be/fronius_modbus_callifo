  "issues": {
    "legacy_modbus_only_entry_reconfigure": {
      "title": "Review Fronius web API access",
      "fix_flow": {
        "step": {
          "init": {
            "title": "Review Fronius System",
            "description": "The entry \"{entry_title}\" needs a valid customer token. Review the host, update interval, and Modbus IP restriction. The next step asks for the customer password only if needed.",
            "data": {
              "host": "Host",
              "scan_interval": "Update interval (seconds)",
              "restrict_modbus_to_this_ip": "Restrict Modbus to this IP"
            }
          },
          "password": {
            "title": "Customer Password",
            "description": "Enter the customer password to create or refresh the stored token.",
            "data": {
              "api_password": "Customer password"
            }
          }
        },
        "error": {
          "cannot_connect": "Failed to connect",
          "invalid_port": "Invalid port number",
          "invalid_host": "Invalid host address",
          "unsupported_hardware": "Unsupported hardware. See logs.",
          "unknown": "Unknown error",
          "scan_interval_too_short": "Minimum update interval is 5 seconds.",
          "modbus_address_conflict": "Modbus IDs are not unique",
          "missing_api_password": "Customer password is required.",
          "invalid_api_credentials": "Customer login failed.",
          "cannot_resolve_local_ip": "Could not determine the Home Assistant IP."
        },
        "abort": {
          "entry_not_found": "The Fronius entry no longer exists."
        },
        "create_entry": {
          "default": "Configuration updated successfully."
        }
      }
    },
    "solar_api_low_firmware": {
      "title": "Disable Fronius Solar API on older firmware",
      "fix_flow": {
        "step": {
          "init": {
            "title": "Disable Solar API",
            "description": "The inverter \"{entry_title}\" is running firmware {current_version}, which is below the safe minimum {minimum_version}. When Solar API stays enabled on older firmware it can cause a memory leak and inverter outages over time. Choose whether to disable Solar API now or ignore this warning.",
            "menu_options": {
              "fix": "Disable Solar API",
              "ignore": "Ignore warning"
            },
            "menu_option_descriptions": {
              "fix": "Recommended for firmware below {minimum_version}.",
              "ignore": "Keep Solar API enabled and hide this warning for now."
            }
          },
          "confirm": {
            "title": "Disable Solar API",
            "description": "Press Submit to disable Solar API on the inverter \"{entry_title}\".",
            "submit": "Disable Solar API",
            "data": {}
          }
        },
        "error": {
          "cannot_connect": "Failed to connect to the inverter.",
          "invalid_api_credentials": "Customer login failed.",
          "unknown": "Unknown error"
        },
        "abort": {
          "entry_not_found": "The Fronius entry no longer exists.",
          "issue_ignored": "The warning was ignored. You can unignore it later from Repairs."
        },
        "create_entry": {
          "default": "Solar API disabled successfully."
        }
      }
    }
  },
