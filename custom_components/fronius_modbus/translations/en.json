{
  "config": {
    "title": "Fronius Modbus",
    "step": {
      "user": {
        "title": "Set up Fronius System",
        "description": "Enter the host, update interval, and Modbus IP restriction. Minimum interval: 5 seconds. If no stored token exists for this host, the next step asks for the customer password.",
        "data": {
          "host": "Host",
          "scan_interval": "Update interval (seconds)",
          "restrict_modbus_to_this_ip": "Restrict Modbus to this IP"
        }
      },
      "user_password": {
        "title": "Customer Password",
        "description": "Enter the customer password to create or refresh the stored token. The password is not stored in the config entry.",
        "data": {
          "api_password": "Customer password",
          "technician_password": "Technician password (optional)"
        },
        "data_description": {
          "technician_password": "Required to enable the Export Limit Control (Soft Limit) setter. Leave empty to skip."
        }
      },
      "reconfigure": {
        "title": "Review Fronius System",
        "description": "Review the host, update interval, and Modbus IP restriction. Minimum interval: 5 seconds. If the stored token is missing or invalid, the next step asks for the customer password.",
        "data": {
          "host": "Host",
          "scan_interval": "Update interval (seconds)",
          "restrict_modbus_to_this_ip": "Restrict Modbus to this IP"
        }
      },
      "reconfigure_password": {
        "title": "Customer Password",
        "description": "Enter the customer password to create or refresh the stored token.",
        "data": {
          "api_password": "Customer password",
          "technician_password": "Technician password (optional)"
        },
        "data_description": {
          "technician_password": "Required to enable the Export Limit Control (Soft Limit) setter. Leave empty to skip."
        }
      }
    },
    "abort": {
      "reconfigure_successful": "Configuration updated successfully."
    },
    "error": {
      "cannot_connect": "Failed to connect",
      "invalid_port": "Invalid port number",
      "invalid_host": "Invalid host address",
      "unsupported_hardware": "Unsupported hardware. See logs.",
      "unknown": "Unknown error",
      "scan_interval_too_short": "Minimum update interval is 5 seconds.",
      "modbus_address_conflict": "Modbus IDs are not unique",
      "missing_api_password": "Customer password is required.",
      "invalid_api_credentials": "Customer login failed.",
      "cannot_resolve_local_ip": "Could not determine the Home Assistant IP."
    }
  },
